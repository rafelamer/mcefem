Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"s3", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "0.5"}], "/", 
           RowBox[{"Sqrt", "[", 
            RowBox[{"x", "+", "1"}], "]"}]}], ")"}], "*", 
         RowBox[{
          RowBox[{"u", "'"}], "[", "x", "]"}]}], "-", 
        RowBox[{
         RowBox[{"Sqrt", "[", 
          RowBox[{"x", "+", "1"}], "]"}], "*", 
         RowBox[{
          RowBox[{"u", "''"}], "[", "x", "]"}]}], "+", 
        RowBox[{"2", "*", 
         RowBox[{"u", "[", "x", "]"}]}]}], "\[Equal]", 
       RowBox[{"50", 
        RowBox[{"Cos", "[", 
         RowBox[{"3", "x"}], "]"}]}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"u", "[", "0", "]"}], "+", 
        RowBox[{"3", "*", 
         RowBox[{
          RowBox[{"u", "'"}], "[", "0", "]"}]}]}], "\[Equal]", "2"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"u", "'"}], "[", "6", "]"}], "\[Equal]", "1"}]}], "}"}], ",", 
    "u", ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", "6"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.7630379636053667`*^9, 
  3.763037976460499*^9}},ExpressionUUID->"4178852b-498c-4b06-9aa0-\
6132ca5d058c"],

