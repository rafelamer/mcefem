          RowBox[{"u", "'"}], "[", 
          RowBox[{"-", "Pi"}], "]"}]}]}], "\[Equal]", "1"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"u", "'"}], "[", "Pi", "]"}], "\[Equal]", "1"}]}], "}"}], ",",
     "u", ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
