Cell[BoxData[
 RowBox[{"s5p", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"-", "2"}], "x", "*", 
         RowBox[{
          RowBox[{"u", "'"}], "[", "x", "]"}]}], "-", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"x", "^", "2"}], "+", "1"}], ")"}], "*", 
         RowBox[{
          RowBox[{"u", "''"}], "[", "x", "]"}]}], "+", 
        RowBox[{
         RowBox[{"u", "'"}], "[", "x", "]"}], "-", 
        RowBox[{"0.1", 
         RowBox[{"g", "[", "x", "]"}], "*", 
         RowBox[{"u", "[", "x", "]"}]}]}], "\[Equal]", 
       RowBox[{"0.5", 
        RowBox[{"f", "[", "x", "]"}]}]}], ",", 
      RowBox[{
       RowBox[{"u", "[", "0", "]"}], "\[Equal]", "1"}], ",", 
      RowBox[{
       RowBox[{"u", "[", "10", "]"}], "\[Equal]", "10"}]}], "}"}], ",", "u", ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", "10"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{
