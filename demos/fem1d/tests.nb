Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{" ", 
  RowBox[{"s2", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "0.5"}], "/", 
            RowBox[{"Sqrt", "[", 
             RowBox[{"x", "+", "1"}], "]"}]}], ")"}], "*", 
          RowBox[{
           RowBox[{"u", "'"}], "[", "x", "]"}]}], "-", 
         RowBox[{
          RowBox[{"Sqrt", "[", 
           RowBox[{"x", "+", "1"}], "]"}], "*", 
          RowBox[{
           RowBox[{"u", "''"}], "[", "x", "]"}]}], "+", 
         RowBox[{"2", "*", 
          RowBox[{"u", "[", "x", "]"}]}]}], "\[Equal]", 
        RowBox[{"50", 
         RowBox[{"Cos", "[", 
          RowBox[{"3", "x"}], "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"u", "[", "0", "]"}], "\[Equal]", "2"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"u", "'"}], "[", "6", "]"}], "\[Equal]", "1"}]}], "}"}], ",",
      "u", ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "6"}], "}"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.7630353110877867`*^9, 3.763035315623477*^9}, {
  3.763035347838892*^9, 
  3.763035348118848*^9}},ExpressionUUID->"bd421722-f11e-4efa-8b80-\
e8697d638ee3"],

