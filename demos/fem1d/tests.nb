Cell[BoxData[
 RowBox[{
  RowBox[{"g", "[", "x_", "]"}], ":=", 
  RowBox[{"Piecewise", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"x", "-", "1"}], ")"}], "^", "2"}], "-", 
         RowBox[{"1", "/", "2"}]}], ",", 
        RowBox[{"x", "<", "2"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"x", "-", "3"}], ")"}], "^", "2"}], "-", 
         RowBox[{"1", "/", "2"}]}], ",", 
        RowBox[{"x", "<", "4"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"x", "-", "5"}], ")"}], "^", "2"}], "-", 
         RowBox[{"1", "/", "2"}]}], ",", 
        RowBox[{"x", "<", "6"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"x", "-", "7"}], ")"}], "^", "2"}], "-", 
         RowBox[{"1", "/", "2"}]}], ",", 
        RowBox[{"x", "<", "8"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"x", "-", "9"}], ")"}], "^", "2"}], "-", 
         RowBox[{"1", "/", "2"}]}], ",", 
        RowBox[{"x", "\[LessEqual]", "10"}]}], "}"}]}], "}"}], ",", "0"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.763095600225422*^9, 3.763095677995582*^9}, {
  3.7630957103072357`*^9, 3.763095753065065*^9}, {3.763096166488302*^9, 
