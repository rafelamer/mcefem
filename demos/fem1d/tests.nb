Cell[BoxData[
 RowBox[{"s4", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"-", 
          RowBox[{"(", 
           RowBox[{"2", "x"}], ")"}]}], "*", 
         RowBox[{
          RowBox[{"u", "'"}], "[", "x", "]"}]}], "-", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"x", "^", "2"}], "+", "1"}], ")"}], "*", 
         RowBox[{
          RowBox[{"u", "''"}], "[", "x", "]"}]}], "+", 
        RowBox[{"2", 
         RowBox[{
          RowBox[{"u", "'"}], "[", "x", "]"}]}], "+", 
        RowBox[{"2", "*", 
         RowBox[{"Cos", "[", 
          RowBox[{"x", "/", "2"}], "]"}], "*", 
         RowBox[{"u", "[", "x", "]"}]}]}], "\[Equal]", 
       RowBox[{"x", "^", "2"}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"3", "*", 
         RowBox[{"u", "[", 
          RowBox[{"-", "Pi"}], "]"}]}], "-", 
