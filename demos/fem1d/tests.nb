Cell[BoxData[
 RowBox[{"s1", " ", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "0.5"}], "/", 
           RowBox[{"Sqrt", "[", 
            RowBox[{"x", "+", "1"}], "]"}]}], ")"}], "*", 
         RowBox[{
          RowBox[{"u", "'"}], "[", "x", "]"}]}], "-", 
        RowBox[{
         RowBox[{"Sqrt", "[", 
          RowBox[{"x", "+", "1"}], "]"}], "*", 
         RowBox[{
          RowBox[{"u", "''"}], "[", "x", "]"}]}], "+", 
        RowBox[{"2", "*", 
         RowBox[{"u", "[", "x", "]"}]}]}], "\[Equal]", 
       RowBox[{"50", 
        RowBox[{"Cos", "[", 
         RowBox[{"3", "x"}], "]"}]}]}], ",", 
      RowBox[{
       RowBox[{"u", "[", "0", "]"}], "\[Equal]", "2"}], ",", 
      RowBox[{
       RowBox[{"u", "[", "6", "]"}], "\[Equal]", "1"}]}], "}"}], ",", "u", ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", "6"}], "}"}]}], "]"}]}]], "Input",
