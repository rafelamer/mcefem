        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"x", "^", "2"}], "+", "1"}], ")"}], "*", 
         RowBox[{
          RowBox[{"u", "''"}], "[", "x", "]"}]}], "+", 
        RowBox[{
         RowBox[{"u", "'"}], "[", "x", "]"}], "-", 
        RowBox[{"0.1", 
         RowBox[{"g", "[", "x", "]"}], "*", 
         RowBox[{"u", "[", "x", "]"}]}]}], "\[Equal]", 
       RowBox[{"0.5", 
        RowBox[{"f", "[", "x", "]"}]}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"3", "*", 
         RowBox[{"u", "[", "0", "]"}]}], "-", 
